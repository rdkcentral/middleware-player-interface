prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: playerjsonobject
Description: JSON handling utilities for player middleware
Version: @PROJECT_VERSION@
Requires: libcjson
Requires.private: libbaseconversion
Libs: -L${libdir} -lplayerjsonobject
Cflags: -I${includedir}