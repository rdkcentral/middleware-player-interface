prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: playerfbinterface
Description: Firebolt IARM/RFC interface library for player middleware
Version: @PROJECT_VERSION@
Requires: gstreamer-1.0, gstreamer-app-1.0, gstreamer-video-1.0
Requires.private: libplayerlogmanager, libbaseconversion, libplayerjsonobject
Libs: -L${libdir} -lplayerfbinterface
Cflags: -I${includedir}