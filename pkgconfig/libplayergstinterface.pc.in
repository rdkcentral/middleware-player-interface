prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: playergstinterface
Description: Main GStreamer interface library for player middleware
Version: @PROJECT_VERSION@
Requires: gstreamer-1.0 >= 1.18.0, gstreamer-app-1.0, gstreamer-video-1.0
Requires.private: libplayerlogmanager, libbaseconversion, libplayerjsonobject, libplayerfbinterface
Libs: -L${libdir} -lplayergstinterface
Libs.private: -ldl
Cflags: -I${includedir}